TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456:your_bot_token
# Telegram API 地址（默认官方地址，通常不需要改）
TELEGRAM_API_ENDPOINT=https://api.telegram.org/bot%s/%s
# Telegram 代理地址，支持 http/https/socks5，例如 http://127.0.0.1:7890
TELEGRAM_PROXY_URL=
# Telegram 长轮询超时（秒）
TELEGRAM_LONG_POLL_TIMEOUT=60
# Telegram 请求超时（建议 > 长轮询超时）
TELEGRAM_REQUEST_TIMEOUT=75s
# 网页终端对外访问地址（用于 /open 返回链接）
WEB_PUBLIC_BASE_URL=http://127.0.0.1:8083
# 本地调试网页终端时可开启，提供 /term/debug/open 临时发链接接口
WEB_TERM_DEBUG_ENABLED=false
# 网页终端临时链接有效期
WEB_TERM_TOKEN_TTL=5m

# 可选：允许访问机器人的 Telegram 用户 ID，多个用逗号分隔；留空表示不限制
ALLOWED_TELEGRAM_USERS=
# 可选：允许访问的 Telegram 会话 ID（建议只填私聊 chat_id），多个用逗号分隔；留空表示不限制
ALLOWED_TELEGRAM_CHATS=

# 运行参数
SHELL_PATH=/bin/bash
TERMINAL_WORKDIR=.
LISTEN_ADDR=:8083
SESSION_IDLE_TIMEOUT=30m
# 网页终端刷新后可回放的历史事件窗口（默认 24h）
EVENT_HISTORY_TTL=24h
SHUTDOWN_TIMEOUT=8s
MAX_OUTPUT_CHUNK=3000

# 安全策略
# 允许命令前缀：留空表示允许所有命令；不为空时，命令必须以其中一个前缀开头
COMMAND_ALLOW_PREFIXES=
# 命令黑名单关键字：命令中包含任一子串则拒绝执行（不区分大小写）
COMMAND_DENY_SUBSTRINGS=rm -rf,reboot,poweroff,shutdown,mkfs
# 审计日志路径（JSONL 格式，一行一条记录）
AUDIT_LOG_PATH=logs/audit.log

# WebSocket 通道配置（用于后续飞书/前端接入）
WS_TOKEN=
WS_DEFAULT_CHAT_ID=0
