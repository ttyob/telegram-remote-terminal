# 网页终端临时链接有效期
WEB_TERM_TOKEN_TTL=5m

# 运行参数
SHELL_PATH=/bin/bash
TERMINAL_WORKDIR=.
LISTEN_ADDR=:8083
SESSION_IDLE_TIMEOUT=30m
# 网页终端刷新后可回放的历史事件窗口（默认 24h）
EVENT_HISTORY_TTL=24h
SHUTDOWN_TIMEOUT=8s
MAX_OUTPUT_CHUNK=3000

# 安全策略
# 允许命令前缀：留空表示允许所有命令；不为空时，命令必须以其中一个前缀开头
COMMAND_ALLOW_PREFIXES=
# 命令黑名单关键字：命令中包含任一子串则拒绝执行（不区分大小写）
COMMAND_DENY_SUBSTRINGS=rm -rf,reboot,poweroff,shutdown,mkfs
# 审计日志路径（JSONL 格式，一行一条记录）
AUDIT_LOG_PATH=logs/audit.log


# Web 控制台状态持久化（SQLite）
DASHBOARD_DB_PATH=data/dashboard.sqlite
# Web 控制台状态加密密钥（base64；留空表示不加密）
# 生成示例：openssl rand -base64 32
DASHBOARD_ENCRYPTION_KEY=

# 控制台登录鉴权（bcrypt hash；留空表示关闭登录）
# 生成示例：htpasswd -bnBC 12 "" "your_password" | tr -d ':\n'
# CONSOLE_AUTH_PASSWORD_HASH='$2y$12$.riszN1bfRB9V/hPNxRZguIglJDil9JhEhzuUo3ns7u7qhJTR1oiO'
CONSOLE_AUTH_PASSWORD_HASH='$2y$12$6D4zk6G3pQNPfZAR9K/fZe8HnArgHDeogNTZUUh8EdoD21uA7QxUy'
CONSOLE_AUTH_SESSION_TTL=12h

# Docker 构建可选：Go 模块代理配置（网络受限时建议设置）
DOCKER_GOPROXY=https://goproxy.cn,direct
DOCKER_GOSUMDB=sum.golang.google.cn
